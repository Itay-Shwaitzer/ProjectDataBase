@page "/login"
@rendermode InteractiveServer

@using ProjectDataBase.Model
@using ProjectDataBase.Service
@inject DatabaseService dbService
@inject UserSessionService sessionService
@inject NavigationManager nav

<h3>התחברות</h3>

<div>
    <label>שם משתמש:</label>
    <input @bind="userName" />
</div>

<div>
    <label>סיסמה:</label>
    <input type="password" @bind="password" />
</div>

<br />

<button @onclick="LoginUser">התחבר</button>

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

@code {
    private string userName = "";
    private string password = "";
    private string message = "";

    // בודקת אם פרטי ההתחברות נכונים ושומרת את המשתמש המחובר
    private void LoginUser()
    {
        List<User> usersList = dbService.GetAllUsers();

        foreach (User user in usersList)
        {
            if (user.GetUserName() == userName && user.GetPassword() == password)
            {
                // 🔥 HERE — this is where you put it
                sessionService.SetIsLoggedIn(true);
                sessionService.SetUserName(user.GetUserName());
                sessionService.SetRole(user.GetRole());

                message = "התחברת בהצלחה";

                // מעבר לאדמין (אם הוא אדמין)
                if (user.GetRole() == "admin")
                {
                    nav.NavigateTo("/admin");
                }

                return;
            }
        }

        message = "שם משתמש או סיסמה שגויים";
    }
}